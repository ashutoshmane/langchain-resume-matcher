# ============================================================
# LangChain Resume Matcher — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
#
# You can use either OpenAI or DeepSeek as your LLM provider.
# DeepSeek is auto-detected when DEEPSEEK_API_KEY is set.
# ============================================================

# --- LLM Provider: OpenAI ---
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini

# --- LLM Provider: DeepSeek (takes priority if set) ---
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_MODEL=deepseek-chat

# --- Embeddings (uses OpenAI by default) ---
EMBEDDING_MODEL=text-embedding-3-small

# --- Vector Store (chroma or faiss) ---
VECTOR_STORE=chroma

# --- Debug Mode ---
DEBUG=false
